<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <title>뇌 훈련 게임</title>
    <style>
        body {
            text-align: center;
            font-family: sans-serif;
            background: #f0f8ff;
            margin: 0;
            padding: 20px;
        }
        
        h2 {
            margin-bottom: 8px;
        }
        
        p {
            margin: 6px 0;
        }
        
        canvas {
            border: 2px solid #333;
            margin-top: 20px;
            background: #fff;
        }
        
        #previewWrap {
            margin-top: 20px;
        }
        
        #preview {
            width: 300px;
            border: 2px solid #333;
            display: none;
        }
        
        button {
            padding: 10px 18px;
            font-size: 16px;
            margin-top: 15px;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <h2 id="title">🧠 마우스를 올리면 뇌 이름 + 클릭하면 게임 시작</h2>
    <p id="brainName">현재 위치: 없음</p>
    <p id="coords">좌표: (0, 0)</p>

    <canvas id="brainCanvas" width="1200" height="700"></canvas>
    <br>
    <button id="homeBtn" style="display:none;">처음으로</button>

    <div id="previewWrap">
        <img id="preview" alt="부위 확대 미리보기">
    </div>

    <script>
        const canvas = document.getElementById("brainCanvas");
        const ctx = canvas.getContext("2d");
        const titleText = document.getElementById("title");
        const brainText = document.getElementById("brainName");
        const coordsText = document.getElementById("coords");
        const preview = document.getElementById("preview");
        const homeBtn = document.getElementById("homeBtn");

        const img = new Image();
        img.src = "뇌.png";

        const scale = 1.3;
        let imgX = 0;
